# ===========================================================================
# ReadMe.ai — Example environment file
# ---------------------------------------------------------------------------
# Copy to `.env` and adjust for your local environment:
#     cp .env.example .env
#
# NEVER commit a real `.env`. Only this `.env.example` is tracked.
# In production these values are injected by a secrets manager, not a file.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# One of: development | staging | production
APP_ENV=development
APP_NAME=ReadMe.ai API
# Semantic version of the running service (also reported by /version).
APP_VERSION=0.2.0
# Enable verbose, human-readable behaviour. MUST be false in production.
APP_DEBUG=true

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Comma-separated list of allowed CORS origins.
# Use explicit origins in production; "*" is only acceptable in development.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG
# One of: console (dev, human-readable) | json (prod, structured)
LOG_FORMAT=console

# ---------------------------------------------------------------------------
# PostgreSQL (system of record)
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=readme
POSTGRES_PASSWORD=readme_local_password
POSTGRES_DB=readme_ai

# ---------------------------------------------------------------------------
# Qdrant (vector database) — provisioned now, used in a later sprint.
# ---------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ---------------------------------------------------------------------------
# Firebase Authentication
# ---------------------------------------------------------------------------
# Used by the backend to validate the `aud` and `iss` claims of Firebase ID
# tokens. Required in any environment that accepts real tokens. May be left
# empty locally only when token verification is stubbed (e.g. tests).
FIREBASE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Development authentication (LOCAL/DEMO ONLY — never enable in production)
# ---------------------------------------------------------------------------
# When true, the fixed bearer token "development-token" authenticates as a mock
# user, bypassing Firebase. Leave false in staging/production.
DEV_AUTH=false

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Backend for uploaded book files. Only "local" is implemented; "r2" is a
# documented future option.
STORAGE_BACKEND=local
# Base directory for the local storage backend (relative to the API workdir).
STORAGE_LOCAL_PATH=var/storage
# Maximum accepted upload size in bytes (default 50 MiB).
MAX_UPLOAD_SIZE_BYTES=52428800

# ===========================================================================
# The following are placeholders for FUTURE sprints and are NOT read yet.
# They are documented here so the configuration surface is known up front.
# ---------------------------------------------------------------------------
# Cloudflare R2 Storage (Sprint: Upload — cloud backend)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
#
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM (Ollama) — powers contextual word explanations
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=30
