# EditorConfig — https://editorconfig.org
# Top-most EditorConfig file for the ReadMe.ai monorepo.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Python — PEP 8 / Black defaults
[*.py]
indent_size = 4
max_line_length = 88

# Dart / Flutter
[*.dart]
indent_size = 2

# Web, config, and data formats
[*.{yml,yaml,json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2
